---
// src/components/Hero.astro
---

<section id="hero" class="relative min-h-[100vh] lg:min-h-[90vh] flex items-center pt-32 pb-16 lg:pt-24 lg:pb-16 overflow-hidden bg-[#0a0a0f]">
  
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <div class="absolute top-[-10%] right-[-10%] w-[300px] lg:w-[600px] h-[300px] lg:h-[600px] bg-[#a100ff]/20 rounded-full blur-[80px] lg:blur-[120px] animate-pulse"></div>
    <div class="absolute bottom-[-10%] left-[-10%] w-[250px] lg:w-[500px] h-[250px] lg:h-[500px] bg-[#437ceb]/15 rounded-full blur-[80px] lg:blur-[100px]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff05_1px,transparent_1px),linear-gradient(to_bottom,#ffffff05_1px,transparent_1px)] bg-[size:3rem_3rem] lg:bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse:80%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-12 lg:gap-8">
      
      <div class="flex-1 w-full flex flex-col items-center text-center lg:items-start lg:text-left lg:max-w-xl xl:max-w-2xl animate-fade-in"> 
        
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-white/10 bg-white/5 backdrop-blur-md mb-6 md:mb-8">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#a100ff] opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-[#a100ff]"></span>
          </span>
          <span class="text-[9px] md:text-[10px] font-gilroy font-bold text-gray-400 tracking-[0.15em] uppercase">
            Digital Sales Executive — Latam
          </span>
        </div>

        <h1 class="font-poppins text-4xl sm:text-5xl lg:text-[64px] font-bold leading-[1.1] tracking-tight text-white mb-6">
          <span class="block opacity-90">El primer empleado digital para </span>
          <span class="block"></span>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#a100ff] via-[#b656ff] to-[#437ceb]">
            espacios físicos.
          </span>
        </h1>
        
        <p class="font-gilroy text-base sm:text-lg text-gray-400 max-w-md lg:max-w-lg leading-relaxed mb-8 md:mb-10">
          DOMA conecta el conocimiento completo de tu empresa con un <span class="text-white font-semibold">Digital Sales Executive</span>. Disponible 24/7. Consistente. Escalable.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 w-full sm:w-auto">
          <a href="#cta-final" class="w-full sm:w-auto text-center px-8 py-4 rounded-full bg-white text-[#0a0a0f] font-gilroy font-black text-base hover:scale-105 transition-transform shadow-[0_0_25px_rgba(255,255,255,0.2)]">
            Agenda una demo
          </a>
          
        </div>
      </div>

      <div class="flex-1 w-full relative animate-fade-in delay-300 mt-10 lg:mt-0 max-w-sm md:max-w-md lg:max-w-none mx-auto">
        <div class="relative w-full aspect-square md:aspect-[4/5] flex items-center justify-center group">
          
          <div class="absolute w-[80%] h-[80%] border border-white/5 rounded-full animate-[spin_20s_linear_infinite] pointer-events-none z-0"></div>
          <div class="absolute bottom-10 w-[60%] h-32 bg-gradient-to-t from-[#a100ff]/10 to-transparent rounded-full blur-2xl lg:blur-3xl opacity-50 pointer-events-none z-0"></div>

          <div 
            class="relative z-10 w-full h-full flex items-center justify-center"
            style="-webkit-mask-image: linear-gradient(to top, transparent 0%, black 15%, black 100%); mask-image: linear-gradient(to top, transparent 0%, black 15%, black 100%);"
          >
            <img 
              src="./rostro_evaaa.png" 
              alt="DOMA — Digital Sales Executive"
              class="w-full h-full object-contain object-bottom p-2 lg:p-6 group-hover:scale-[1.01] transition-transform duration-700 brightness-110 contrast-110 drop-shadow-[0_0_15px_rgba(161,0,255,0.3)]"
              style="mix-blend-mode: screen;"
            />
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .delay-300 {
    animation-delay: 300ms;
  }
</style>