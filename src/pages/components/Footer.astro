---
// src/components/Footer.astro
---

<footer class="bg-[#0a0a0f] pt-24 pb-12 border-t border-white/5 relative overflow-hidden">
  <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-[#a100ff]/5 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 mb-20">
      
      <div class="lg:col-span-5">
        <a href="#" class="font-poppins font-black text-3xl text-white tracking-tighter mb-6 block">
          DOMA<span class="text-[#a100ff]">.</span>
        </a>
        <p class="font-gilroy text-gray-400 text-lg max-w-sm leading-relaxed mb-8">
          El Digital Sales Executive para espacios físicos. 
          <span class="block mt-2 text-white/50 text-sm font-bold uppercase tracking-widest">Hecho en México.</span>
        </p>
        
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 rounded-full border border-white/10 bg-white/5 flex items-center justify-center text-white hover:bg-[#a100ff] hover:border-[#a100ff] hover:-translate-y-1 transition-all duration-300" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full border border-white/10 bg-white/5 flex items-center justify-center text-white hover:bg-[#437ceb] hover:border-[#437ceb] hover:-translate-y-1 transition-all duration-300" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        </div>
      </div>

      <div class="lg:col-span-2">
        <h4 class="font-gilroy font-bold text-white uppercase tracking-[0.2em] text-xs mb-8">Producto</h4>
        <ul class="space-y-4">
          <li><a href="#producto" class="font-gilroy text-gray-500 hover:text-[#a100ff] transition-colors">El tótem físico</a></li>
          <li><a href="#producto" class="font-gilroy text-gray-500 hover:text-[#a100ff] transition-colors">QOPA Intelligence</a></li>
          <li><a href="#modelo" class="font-gilroy text-gray-500 hover:text-[#a100ff] transition-colors">Modelo DSE</a></li>
        </ul>
      </div>

      <div class="lg:col-span-3">
        <h4 class="font-gilroy font-bold text-white uppercase tracking-[0.2em] text-xs mb-8">Industrias</h4>
        <div class="grid grid-cols-1 gap-4">
          <a href="#industrias" class="font-gilroy text-gray-500 hover:text-white transition-colors">Retail & Mall</a>
          <a href="#industrias" class="font-gilroy text-gray-500 hover:text-white transition-colors">Transporte</a>
          <a href="#industrias" class="font-gilroy text-gray-500 hover:text-white transition-colors">Hospitality</a>
          <a href="#industrias" class="font-gilroy text-gray-500 hover:text-white transition-colors">Banca & Seguros</a>
          <a href="#industrias" class="font-gilroy text-gray-500 hover:text-white transition-colors">Gobierno</a>
        </div>
      </div>

      <div class="lg:col-span-2">
        <h4 class="font-gilroy font-bold text-white uppercase tracking-[0.2em] text-xs mb-8">Empresa</h4>
        <ul class="space-y-4">
          <li><a href="#" class="font-gilroy text-gray-500 hover:text-white transition-colors">Sobre DOMA</a></li>
          <li><a href="#faq" class="font-gilroy text-gray-500 hover:text-white transition-colors">FAQ</a></li>
          <li><a href="#" class="font-gilroy text-gray-500 hover:text-white transition-colors">Contacto</a></li>
          <li><a href="#cta-final" class="font-gilroy text-[#a100ff] font-bold hover:brightness-125 transition-all underline underline-offset-8">Agendar Demo</a></li>
        </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-gilroy text-gray-600 text-sm">
        © 2026 DOMA Digital. Todos los derechos reservados.
      </p>
      <div class="flex gap-8">
        <a href="#" class="font-gilroy text-gray-600 text-xs hover:text-gray-400 transition-colors uppercase tracking-widest">Aviso de Privacidad</a>
        <a href="#" class="font-gilroy text-gray-600 text-xs hover:text-gray-400 transition-colors uppercase tracking-widest">Términos</a>
      </div>
    </div>
  </div>
</footer>