---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="relative pb-20 px-4 sm:px-6 bg-[#0a0a0f] overflow-hidden">
  
  {/* 1. EL GLOW DE FONDO (Colores de DOMA: Púrpura y Azul) */}
  <div class="absolute bottom-0 left-0 right-0 h-[500px] bg-gradient-to-t from-[#a100ff]/10 via-[#437ceb]/5 to-transparent pointer-events-none"></div>
  <div class="absolute -bottom-20 -left-20 w-[400px] h-[400px] bg-[#a100ff]/20 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute -bottom-20 -right-20 w-[400px] h-[400px] bg-[#437ceb]/15 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    
    {/* 2. LA TARJETA PRINCIPAL (Estilo Firebase Studio - Over Glow) */}
    <div class="bg-[#0f0f15]/80 backdrop-blur-3xl border border-white/5 rounded-[40px] p-8 md:p-16 shadow-2xl overflow-hidden relative group">
      
      {/* Resplandor interior sutil */}
      <div class="absolute inset-0 bg-gradient-to-br from-white/[0.02] to-transparent pointer-events-none"></div>

      {/* Top Section: Logo y Status */}
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-20 gap-8 relative z-10">
        <div class="flex flex-col gap-4">
            <a href="/" class="font-poppins font-black text-4xl text-white tracking-tighter">
                DOMA<span class="text-[#a100ff]"></span>
            </a>
            <p class="font-gilroy text-gray-400 text-lg max-w-xs leading-relaxed">
                El Digital Sales Executive para espacios físicos. 
                <span class="block mt-1 text-[#437ceb] text-xs font-bold uppercase tracking-[0.2em]">Hecho en México.</span>
            </p>
        </div>

        
      </div>

      {/* Grid de Links */}
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-12 mb-20 relative z-10">
        <div>
          <h4 class="font-gilroy font-bold text-white uppercase tracking-[0.2em] text-xs mb-8">Producto</h4>
          <ul class="space-y-4">
            <li><a href="#producto" class="font-gilroy text-gray-500 hover:text-[#a100ff] transition-colors text-sm">El tótem físico</a></li>
            <li><a href="#qopa" class="font-gilroy text-gray-500 hover:text-[#a100ff] transition-colors text-sm">QOPA Intelligence</a></li>
            <li><a href="#modelo" class="font-gilroy text-gray-500 hover:text-[#a100ff] transition-colors text-sm">Modelo DSE</a></li>
          </ul>
        </div>

        <div>
          <h4 class="font-gilroy font-bold text-white uppercase tracking-[0.2em] text-xs mb-8">Industrias</h4>
          <ul class="space-y-4">
            <li><a href="#industrias" class="font-gilroy text-gray-500 hover:text-white transition-colors text-sm">Retail & Mall</a></li>
            <li><a href="#industrias" class="font-gilroy text-gray-500 hover:text-white transition-colors text-sm">Transporte & Hospitalidad</a></li>
            <li><a href="#industrias" class="font-gilroy text-gray-500 hover:text-white transition-colors text-sm">Banca & Seguros</a></li>
          </ul>
        </div>

        <div>
          <h4 class="font-gilroy font-bold text-white uppercase tracking-[0.2em] text-xs mb-8">Empresa</h4>
          <ul class="space-y-4">
            <li><a href="#" class="font-gilroy text-gray-500 hover:text-white transition-colors text-sm">Sobre DOMA</a></li>
            <li><a href="#faq" class="font-gilroy text-gray-500 hover:text-white transition-colors text-sm">FAQ</a></li>
            <li><a href="mailto:hola@doma.ai" class="font-gilroy text-gray-500 hover:text-white transition-colors text-sm">Contacto</a></li>
          </ul>
        </div>

        <div>
          <h4 class="font-gilroy font-bold text-white uppercase tracking-[0.2em] text-xs mb-8">Social</h4>
          <div class="flex gap-4 mb-6">
            <a href="#" class="w-10 h-10 rounded-xl border border-white/10 bg-white/5 flex items-center justify-center text-white hover:bg-[#a100ff] hover:border-[#a100ff] hover:-translate-y-1 transition-all duration-300" aria-label="LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="#" class="w-10 h-10 rounded-xl border border-white/10 bg-white/5 flex items-center justify-center text-white hover:bg-[#437ceb] hover:border-[#437ceb] hover:-translate-y-1 transition-all duration-300" aria-label="Instagram">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          </div>
          <a href="#cta-final" class="inline-block font-gilroy text-[#a100ff] font-bold hover:brightness-125 transition-all underline underline-offset-8 text-sm">Agendar Demo</a>
        </div>
      </div>

      {/* Bottom Bar */}
      <div class="pt-10 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 relative z-10">
        <div class="flex flex-col md:flex-row items-center gap-4 md:gap-8">
            <p class="font-gilroy text-gray-600 text-sm">
                © {currentYear} DOMA Digital Hecho en México.
            </p>
            
        </div>

      </div>

    </div>

  </div>
</footer>