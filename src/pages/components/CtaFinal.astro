---
// src/components/CtaFinal.astro
---

<section id="cta-final" class="py-24 relative overflow-hidden bg-[#0a0a0f]">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[500px] bg-gradient-to-r from-[#a100ff]/20 to-[#437ceb]/20 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-5xl mx-auto bg-white/[0.02] border border-white/10 backdrop-blur-2xl rounded-[40px] p-8 md:p-16 text-center shadow-2xl relative overflow-hidden group">
      
      <div class="absolute inset-0 bg-gradient-to-br from-white/[0.05] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

      <div class="relative z-10">
        <h2 class="font-poppins text-4xl md:text-6xl font-bold text-white mb-6 leading-tight tracking-tighter">
          ¿Listo para tu primer<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#a100ff] to-[#437ceb]">
            Digital Sales Executive?
          </span>
        </h2>
        
        <p class="font-gilroy text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
          30 minutos. Te mostramos <span class="text-white">DOMA</span> en acción y construimos el caso de negocio para tu industria.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-5 mb-12">
          <a 
            href="mailto:hola@doma.ai" 
            class="w-full sm:w-auto px-10 py-5 rounded-full bg-white text-[#0a0a0f] font-gilroy font-black text-lg hover:scale-105 transition-all shadow-[0_0_40px_rgba(255,255,255,0.2)] active:scale-95"
          >
            Agenda una demo
          </a>
          
          <a 
            href="https://wa.me/5215500000000" 
            target="_blank"
            class="w-full sm:w-auto px-10 py-5 rounded-full border border-white/10 bg-white/5 text-white font-gilroy font-bold text-lg backdrop-blur-md hover:bg-white/10 hover:border-white/20 transition-all flex items-center justify-center gap-3"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-green-500">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp directo
          </a>
        </div>

        <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4 border-t border-white/5 pt-8">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-[#a100ff]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-gray-300 font-gilroy text-sm font-bold uppercase tracking-widest">Sin compromiso</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-[#a100ff]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-gray-300 font-gilroy text-sm font-bold uppercase tracking-widest">Demo personalizada</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-[#a100ff]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-gray-300 font-gilroy text-sm font-bold uppercase tracking-widest">Propuesta en 48h</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>